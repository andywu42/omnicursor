# Pin upstream source refs to a branch, tag, or commit SHA for reproducible builds.
OMNIINTELLIGENCE_REF=main

# Core infrastructure credentials.
POSTGRES_PASSWORD=omnicursor-dev-postgres
VALKEY_PASSWORD=valkey-dev-password

# Host ports.
POSTGRES_EXTERNAL_PORT=5436
VALKEY_EXTERNAL_PORT=16379
REDPANDA_EXTERNAL_PORT=19092
REDPANDA_PANDAPROXY_PORT=18082
REDPANDA_SCHEMA_REGISTRY_PORT=18081
REDPANDA_ADMIN_PORT=19644

# OmniIntelligence service ports.
INTELLIGENCE_REDUCER_PORT=18091
INTELLIGENCE_ORCHESTRATOR_PORT=18092
QUALITY_SCORING_COMPUTE_PORT=18093

# Optional memory profile ports.
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MEMGRAPH_BOLT_PORT=7687
MEMGRAPH_HTTP_PORT=7444
KREUZBERG_PORT=8090

# OmniCursor pattern sync (Option B — requires compose stack running).
# Set to 1 to pull patterns from intelligence-reducer after each session.
# Local patterns are never sent upstream; this is a read-only pull.
# Overrideable base URL: OMNIINTELLIGENCE_URL=http://127.0.0.1:18091
OMNICURSOR_PATTERN_SYNC_HTTP=0

# Optional tuning.
LOG_LEVEL=INFO
MAX_CONCURRENT_WORKFLOWS=10
WORKFLOW_TIMEOUT_SECONDS=300
ENABLE_CACHING=true
CACHE_TTL_SECONDS=300

# OmniCursor local bridge — Option B mínima
# Path to local omnimarket checkout. Must already exist; never cloned at runtime.
# Bridge code (omnimarket_bridge.py) falls back to omnimarket-main/ in the repo root if unset.
OMNIMARKET_ROOT=/path/to/local/omnimarket

# URL of the omniintelligence reducer for pattern_sync read path.
# Defaults to http://127.0.0.1:18091 (compose stack port).
# Only used when OMNICURSOR_PATTERN_SYNC_HTTP=1.
OMNIINTELLIGENCE_URL=http://127.0.0.1:18091

# Set to 1 to enable HTTP pattern sync from omniintelligence after each session.
# Default off — local learned_patterns.json is the authoritative read cache.
OMNICURSOR_PATTERN_SYNC_HTTP=0

# Override the outbox file path (default: ~/.omnicursor/outbox.jsonl).
# Set in tests or CI to redirect outbox writes to a temporary file.
OMNICURSOR_OUTBOX_FILE=~/.omnicursor/outbox.jsonl
