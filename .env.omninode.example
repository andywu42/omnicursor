# Pin upstream source refs to a branch, tag, or commit SHA for reproducible builds.
OMNIINTELLIGENCE_REF=main

# Core infrastructure credentials.
POSTGRES_PASSWORD=omnicursor-dev-postgres
VALKEY_PASSWORD=valkey-dev-password

# Host ports.
POSTGRES_EXTERNAL_PORT=5436
VALKEY_EXTERNAL_PORT=16379
REDPANDA_EXTERNAL_PORT=19092
REDPANDA_PANDAPROXY_PORT=18082
REDPANDA_SCHEMA_REGISTRY_PORT=18081
REDPANDA_ADMIN_PORT=19644

# OmniIntelligence service ports.
INTELLIGENCE_REDUCER_PORT=18091
INTELLIGENCE_ORCHESTRATOR_PORT=18092
QUALITY_SCORING_COMPUTE_PORT=18093

# Optional memory profile ports.
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MEMGRAPH_BOLT_PORT=7687
MEMGRAPH_HTTP_PORT=7444
KREUZBERG_PORT=8090

# Local OmniNode checkout paths (machine-specific — never committed).
# These directories are gitignored. Point them at local clones.
OMNIMARKET_ROOT=/path/to/omnimarket        # required for run_ticket_pipeline via MCP bridge
OMNIDASH_ROOT=/path/to/omnidash            # optional — only needed for run_omnidash_bridge.sh

# OmniDash fixture dir — where run_omnidash_bridge.sh writes JSON fixtures.
# OmniDash reads these when running locally (npm run dev in the omnidash repo).
OMNIDASH_FIXTURES_DIR=/tmp/omnicursor-omnidash-fixtures

# Options B+C — omniintelligence integration (requires compose stack).
# Intelligence service URL — single-sourced: read by both the per-prompt
# pattern fetch and the session-end HTTP sync. (The old OMNIINTELLIGENCE_URL
# name is a deprecated fallback for the sync path, one release.)
INTELLIGENCE_SERVICE_URL=http://localhost:18091
OMNICURSOR_PATTERN_SYNC_HTTP=1

# Optional tuning.
LOG_LEVEL=INFO
MAX_CONCURRENT_WORKFLOWS=10
WORKFLOW_TIMEOUT_SECONDS=300
ENABLE_CACHING=true
CACHE_TTL_SECONDS=300

# Override the outbox file path (default: ~/.omnicursor/outbox.jsonl).
# Set in tests or CI to redirect outbox writes to a temporary file.
OMNICURSOR_OUTBOX_FILE=~/.omnicursor/outbox.jsonl
