# Pin upstream source refs to a branch, tag, or commit SHA for reproducible builds.
OMNIINTELLIGENCE_REF=main

# Core infrastructure credentials.
POSTGRES_PASSWORD=omnicursor-dev-postgres
VALKEY_PASSWORD=valkey-dev-password

# Host ports.
POSTGRES_EXTERNAL_PORT=5436
VALKEY_EXTERNAL_PORT=16379
REDPANDA_EXTERNAL_PORT=19092
REDPANDA_PANDAPROXY_PORT=18082
REDPANDA_SCHEMA_REGISTRY_PORT=18081
REDPANDA_ADMIN_PORT=19644

# OmniIntelligence service ports.
INTELLIGENCE_REDUCER_PORT=18091
INTELLIGENCE_ORCHESTRATOR_PORT=18092
QUALITY_SCORING_COMPUTE_PORT=18093

# Optional memory profile ports.
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
MEMGRAPH_BOLT_PORT=7687
MEMGRAPH_HTTP_PORT=7444
KREUZBERG_PORT=8090

# Optional tuning.
LOG_LEVEL=INFO
MAX_CONCURRENT_WORKFLOWS=10
WORKFLOW_TIMEOUT_SECONDS=300
ENABLE_CACHING=true
CACHE_TTL_SECONDS=300
